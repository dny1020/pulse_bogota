# Copy to .env and fill what you have.
# Collectors degrade gracefully: a missing key just drops that signal and
# lowers the activity confidence. Open-Meteo (weather) needs no key.

# PostgreSQL password (REQUIRED for docker compose — used by both containers).
# Generate one with: openssl rand -hex 24
POSTGRES_PASSWORD=

# Database URL used when running the app OUTSIDE docker (uvicorn --reload,
# tests). Inside docker compose this is overridden to point at the db service.
DATABASE_URL=sqlite:///./pulse_bogota.db

# Background scheduler (set false in tests / one-off scripts)
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=15

# External APIs (leave blank to disable that collector)
TOMTOM_API_KEY=
GOOGLE_PLACES_API_KEY=
