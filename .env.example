# Copy to .env and fill what you have.
# Collectors degrade gracefully: a missing key just drops that signal and
# lowers the activity confidence. Open-Meteo (weather) needs no key.

# PostgreSQL password (REQUIRED for docker compose — used by both containers).
# Generate one with: openssl rand -hex 24
POSTGRES_PASSWORD=

# Database URL used when running the app OUTSIDE docker (uvicorn --reload,
# tests). Inside docker compose this is overridden to point at the db service.
DATABASE_URL=sqlite:///./pulse_bogota.db

# Background scheduler (set false in tests / one-off scripts)
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=15

# Logging: DEBUG / INFO / WARNING / ERROR. LOG_FILE blank = console only
# (docker compose sets LOG_FILE to /app/logs/pulse_bogota.log on the ./logs mount).
LOG_LEVEL=INFO
LOG_FILE=

# External APIs (leave blank to disable that collector)
TOMTOM_API_KEY=
GOOGLE_PLACES_API_KEY=
TICKETMASTER_API_KEY=

# Events collector: search radius per place and look-ahead window
EVENTS_RADIUS_KM=2
EVENTS_WINDOW_HOURS=24

# Activity forecasting. A weekly job trains a model; it is only used for a place
# once it has FORECAST_MIN_SAMPLES history rows, otherwise the hourly-profile
# baseline is used. FORECAST_MODEL_PATH persists the trained artifact.
FORECAST_ENABLED=true
FORECAST_MIN_SAMPLES=200
FORECAST_MODEL_PATH=./data/forecast_model.joblib

# Weekly Google Places rating refresh (needs GOOGLE_PLACES_API_KEY).
GOOGLE_REFRESH_ENABLED=true

# OSM importer: the per-run limit grows with the catalogue, capped at the max.
OSM_IMPORT_LIMIT=50
OSM_IMPORT_LIMIT_MAX=500
OSM_IMPORT_GROWTH=1.2

# Anomaly detection: flag readings whose z-score crosses this threshold.
ANOMALY_DETECTION_ENABLED=true
ANOMALY_ZSCORE_THRESHOLD=3.0
